package-as: Roman
enable-nolib-creation: no

externals:
  Libraries\LibInit: https://github.com/alarofrunetotem/LibInit.git/LibInit
  Libraries\LibDBIcon-1.0: https://repos.curseforge.com/wow/libdbicon-1-0/trunk
  Libraries\LibDialog-1.0: https://repos.curseforge.com/wow/libdialog-1-0

ignore:
  - .git
  - .gitattributes
  - .gitignore
  - template.lua
  - .mklink

optional-dependencies:
  - LibInit
  - LibDialog-1.0
  - LibDBIcon-1.0

license-output: LICENSE

tools-used:
    - libdatabroker-1-1
